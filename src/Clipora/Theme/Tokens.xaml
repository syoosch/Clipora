<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- 间距刻度 (px) -->
    <sys:Double x:Key="SpaceXs">4</sys:Double>
    <sys:Double x:Key="SpaceSm">8</sys:Double>
    <sys:Double x:Key="SpaceMd">12</sys:Double>
    <sys:Double x:Key="SpaceLg">16</sys:Double>
    <sys:Double x:Key="SpaceXl">24</sys:Double>

    <!-- 常用内 / 外边距 -->
    <Thickness x:Key="CardPadding">12,10,12,10</Thickness>
    <Thickness x:Key="ListItemMargin">0,0,14,4</Thickness>
    <Thickness x:Key="PanelPadding">12</Thickness>

    <!-- 圆角：卡片偏大、窗口偏大、chips 胶囊 -->
    <CornerRadius x:Key="RadiusCard">10</CornerRadius>
    <CornerRadius x:Key="RadiusWindow">12</CornerRadius>
    <CornerRadius x:Key="RadiusPill">20</CornerRadius>

    <!-- 字号层级 -->
    <sys:Double x:Key="FontTitle">14</sys:Double>
    <sys:Double x:Key="FontBody">13</sys:Double>
    <sys:Double x:Key="FontMeta">12</sys:Double>

    <!-- 动画时长 -->
    <Duration x:Key="DurFast">0:0:0.12</Duration>
    <Duration x:Key="DurBase">0:0:0.20</Duration>
    <Duration x:Key="DurSlow">0:0:0.30</Duration>
</ResourceDictionary>
