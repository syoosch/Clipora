<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 液态玻璃 · 深色变体（M8 Phase C）。
         覆盖 WPF-UI 画刷键为半透明深色玻璃值；Acrylic 窗口背景由 ThemeService 设置。
         玻璃亮边 = CardStrokeColorDefaultBrush 用竖向渐变（顶亮→底淡）做 rim，纯画刷、不改模板。
         禁止改 Theme/Styles.xaml / Tokens.xaml（Fluent 基线）。 -->

    <!-- 窗口 / 应用底：透明，让 Acrylic 透出（强玻璃通透） -->
    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="#00000000" />

    <!-- 卡片表面（半透明深面） -->
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#5C32323A" />
    <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#4232323A" />

    <!-- 玻璃亮边 rim：竖向渐变（顶部轻亮→底淡） -->
    <LinearGradientBrush x:Key="CardStrokeColorDefaultBrush" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Offset="0" Color="#5CFFFFFF" />
        <GradientStop Offset="1" Color="#14FFFFFF" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="CardStrokeColorDefaultSolidBrush" Color="#3DFFFFFF" />

    <!-- chips / 控件填充：常态 / 悬停（更亮）/ 按下（更淡）/ 禁用 -->
    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="#2EFFFFFF" />
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="#40FFFFFF" />
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="#21FFFFFF" />
    <SolidColorBrush x:Key="ControlFillColorDisabledBrush" Color="#14FFFFFF" />

    <!-- 按钮 / 菜单项 hover 的 Subtle 填充 -->
    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="#29FFFFFF" />
    <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="#1AFFFFFF" />

    <!-- 托盘菜单 / 对话框等实体表面：磨砂深面，保证可读 -->
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="#FF2A2A30" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="#A6222227" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorTertiaryBrush" Color="#991C1C20" />

    <!-- WPF-UI 分层表面 -->
    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="#4232323A" />
    <SolidColorBrush x:Key="LayerFillColorAltBrush" Color="#2632323A" />

    <!-- 控件描边：轻亮玻璃边 -->
    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="#38FFFFFF" />
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="#1FFFFFFF" />

</ResourceDictionary>
