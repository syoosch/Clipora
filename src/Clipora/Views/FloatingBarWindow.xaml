<Window x:Class="Clipora.Views.FloatingBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="14"
        Height="68"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Cursor="Hand"
        AllowDrop="True"
        MouseEnter="Surface_MouseEnter"
        MouseLeave="Surface_MouseLeave"
        MouseLeftButtonDown="Surface_MouseLeftButtonDown"
        MouseMove="Surface_MouseMove"
        MouseLeftButtonUp="Surface_MouseLeftButtonUp"
        DragEnter="Surface_DragEnter"
        DragOver="Surface_DragOver"
        DragLeave="Surface_DragLeave"
        Drop="Surface_Drop">

    <Grid Background="Transparent">
        <Border x:Name="Handle"
                Width="10"
                Height="68"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                CornerRadius="5"
                Background="{DynamicResource TextFillColorTertiaryBrush}"
                Opacity="0.58">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Window}}"
                                     Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="14"
                                                         Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="0.82"
                                                         Duration="0:0:0.12" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="10"
                                                         Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="0.58"
                                                         Duration="0:0:0.16" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <!-- 拖入方块的居中图标：叠在条之上，不受条 0.58 半透明影响；颜色加深以从背景凸显。
             默认透明，形变成方块时淡入。IsHitTestVisible=False 不干扰窗口接拖放命中。 -->
        <TextBlock x:Name="DropGlyph"
                   Text="&#xE8B7;"
                   FontFamily="Segoe Fluent Icons"
                   FontSize="30"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"
                   Opacity="0"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
    </Grid>
</Window>
