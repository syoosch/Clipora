<ui:FluentWindow x:Class="Clipora.Views.StorageStartupWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Clipora"
                 Icon="pack://application:,,,/Assets/clipora-icon.png"
                 Width="420" Height="310"
                 MinWidth="380" MinHeight="280"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 ShowInTaskbar="True">
    <Grid Margin="26,22,26,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="HeadingText"
                       FontFamily="Segoe UI Variable Display"
                       FontSize="21"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <TextBlock x:Name="SubheadingText"
                       Margin="0,7,0,0"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,20,0,18">
            <StackPanel x:Name="ProgressPanel" VerticalAlignment="Center">
                <ui:ProgressRing x:Name="ProgressRing"
                                 Width="34" Height="34"
                                 IsIndeterminate="True"
                                 HorizontalAlignment="Left" />
                <ProgressBar x:Name="CopyProgressBar"
                             Margin="0,18,0,0"
                             Height="5"
                             Minimum="0" Maximum="1"
                             Visibility="Collapsed" />
                <TextBlock x:Name="StageText"
                           Margin="0,12,0,0"
                           FontSize="14"
                           FontWeight="Medium"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            </StackPanel>

            <StackPanel x:Name="FailurePanel" Visibility="Collapsed">
                <TextBlock x:Name="FailureText"
                           TextWrapping="Wrap"
                           FontSize="13"
                           Foreground="{DynamicResource SystemFillColorCriticalBrush}" />
                <TextBlock x:Name="FailurePathText"
                           Margin="0,12,0,0"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="FailureHintText"
                           Margin="0,12,0,0"
                           TextWrapping="Wrap"
                           FontSize="11"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            </StackPanel>
        </Grid>

        <StackPanel x:Name="ActionPanel"
                    Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Visibility="Collapsed">
            <ui:Button x:Name="UseDefaultButton"
                       Margin="0,0,8,0"
                       Content="使用默认位置"
                       Click="UseDefault_Click" />
            <ui:Button x:Name="RetryButton"
                       Margin="0,0,8,0"
                       Content="重试"
                       Appearance="Primary"
                       Click="Retry_Click" />
            <ui:Button Content="退出" Click="Exit_Click" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
